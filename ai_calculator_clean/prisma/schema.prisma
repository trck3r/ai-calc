
generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model CalculatorResult {
  id                 String   @id @default(cuid())
  email              String

  // Diagnostic inputs
  monthlyRevenue     String
  industry           String
  teamSize           String
  clientSources      String[]
  marketingSetup     String
  monthlyAdSpend     String
  leadFollowUpTime   String
  noShowRate         String
  biggestBottleneck  String

  // Calculated results
  monthlyLeak        Float
  annualLeak         Float
  systemScore        Int
  weeksToFix         Int
  followUpLeakPct    Int
  noShowLeakPct      Int
  systemLeakPct      Int
  recommendations    String[]
  severityLevel      String

  // Metadata
  ghlContactId       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("calculator_results")
}

model EmailCapture {
  id                String   @id @default(cuid())
  email             String   @unique
  source            String
  calculatorResultId String?
  createdAt         DateTime @default(now())

  @@map("email_captures")
}
